# ==================================
# APPLICATION CONFIGURATION
# ==================================
NODE_ENV=development
PORT=3000

# ==================================
# DATABASE CONFIGURATION
# ==================================
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=your_database_user
DB_PASSWORD=your_database_password
DB_DATABASE=spendwise_auth
DB_SYNCHRONIZE=false
DB_LOGGING=false

# ==================================
# JWT CONFIGURATION
# ==================================
# Generate strong secrets using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your_jwt_access_secret_here_minimum_32_characters
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here_minimum_32_characters
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ==================================
# TOKEN EXPIRATION
# ==================================
EMAIL_VERIFICATION_TOKEN_EXPIRATION=1h
PASSWORD_RESET_TOKEN_EXPIRATION=20m

# ==================================
# EMAIL CONFIGURATION
# ==================================
# Option 1: MailHog (for local development)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=noreply@spendwise.com
MAIL_FROM_NAME=SpendWise

# Option 2: Resend (for production)
# MAIL_HOST=smtp.resend.com
# MAIL_PORT=587
# MAIL_USER=resend
# MAIL_PASSWORD=your_resend_api_key_here
# MAIL_FROM=onboarding@yourdomain.com
# MAIL_FROM_NAME=Your App Name

# ==================================
# URL CONFIGURATION
# ==================================
API_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# ==================================
# EMAIL VALIDATION
# ==================================
EMAIL_VALIDATION_ENABLED=true
EMAIL_VALIDATION_PROVIDER=deep-validator

# ZeroBounce (optional - if using paid service)
# EMAIL_VALIDATION_PROVIDER=zerobounce
# ZEROBOUNCE_API_KEY=your_zerobounce_api_key_here
# ZEROBOUNCE_API_URL=https://api.zerobounce.net/v2

# ==================================
# SECURITY CONFIGURATION
# ==================================
# Password hashing rounds (10-12 recommended)
BCRYPT_ROUNDS=10

# Token generation bytes
TOKEN_BYTES=32

# Email verification expiration (hours)
EMAIL_VERIFICATION_HOURS=1

# Password reset expiration (minutes)
PASSWORD_RESET_MINUTES=20

# ==================================
# RATE LIMITING CONFIGURATION
# ==================================
# Time-to-live in milliseconds (60000 = 1 minute)
THROTTLE_TTL=60000

# Maximum requests per TTL window
THROTTLE_LIMIT=20

# ==================================
# ACCOUNT LOCKOUT CONFIGURATION
# ==================================
# Maximum failed login attempts before lockout
MAX_LOGIN_ATTEMPTS=5

# Lockout duration in minutes
LOCKOUT_DURATION_MINUTES=30